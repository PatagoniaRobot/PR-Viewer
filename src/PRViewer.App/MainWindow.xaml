<Window x:Class="PRViewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRViewer.App.ViewModels"
        xmlns:pv="clr-namespace:PRViewer.App.ViewModels.Previews"
        xmlns:conv="clr-namespace:PRViewer.App.Converters"
        Title="PR-Viewer — visor forense de solo lectura"
        Height="760" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:SenderBrushConverter x:Key="SenderBrush" />

        <!-- ══ Preview: conversación parseada + texto crudo ══ -->
        <DataTemplate DataType="{x:Type pv:ChatPreviewViewModel}">
            <TabControl>
                <TabItem Header="Mensajes">
                    <ListBox ItemsSource="{Binding Messages}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <!-- Mensaje de sistema: centrado y tenue -->
                                    <TextBlock Text="{Binding Text}"
                                               Visibility="{Binding IsSystemMessage, Converter={StaticResource BoolToVis}}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               FontStyle="Italic" FontSize="11"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               HorizontalAlignment="Center" MaxWidth="560" />
                                    <!-- Mensaje normal -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TimestampText}"
                                                       Style="{StaticResource MonoText}" FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Sender}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0"
                                                       Foreground="{Binding SenderIndex, Converter={StaticResource SenderBrush}}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Margin="0,2,0,0" MaxWidth="720" HorizontalAlignment="Left" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                    Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="📎 " Foreground="{StaticResource AccentCyanBrush}" />
                                            <TextBlock Text="{Binding AttachmentName}"
                                                       Style="{StaticResource MonoText}" FontSize="11"
                                                       Foreground="{StaticResource AccentCyanBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="Texto crudo">
                    <TextBox Text="{Binding RawText, Mode=OneWay}" IsReadOnly="True"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </TabItem>
            </TabControl>
        </DataTemplate>

        <!-- ══ Preview: texto plano genérico ══ -->
        <DataTemplate DataType="{x:Type pv:TextPreviewViewModel}">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" Margin="12,0,0,0" />
                </StackPanel>
                <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextBrush}"
                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </DockPanel>
        </DataTemplate>

        <!-- ══ Preview: JSON navegable ══ -->
        <DataTemplate DataType="{x:Type pv:JsonPreviewViewModel}">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" Margin="12,0,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorText}"
                           Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                <TreeView ItemsSource="{Binding RootNodes}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentCyanBrush}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />
                                <TextBlock Text=" : " Foreground="{StaticResource TextDimBrush}" />
                                <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource TextBrush}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </DataTemplate>

        <!-- ══ Preview: imagen (sujeta a visibilidad de multimedia) ══ -->
        <DataTemplate DataType="{x:Type pv:ImagePreviewViewModel}">
            <DockPanel Margin="8">
                <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
                        CornerRadius="4" Padding="10" Margin="0,8,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" Margin="12,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding Sha256, StringFormat=SHA-256: {0}}"
                                   Style="{StaticResource MonoText}" FontSize="11" Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid>
                    <!-- Placeholder de privacidad: el contenido arranca oculto -->
                    <Border Background="{StaticResource PanelAltBrush}" CornerRadius="6"
                            Visibility="{Binding IsContentHidden, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="42" HorizontalAlignment="Center" />
                            <TextBlock Text="Contenido visual oculto" Foreground="{StaticResource TextBrush}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,2" />
                            <TextBlock Text="El material sensible no se muestra hasta que lo decidas."
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12"
                                       HorizontalAlignment="Center" />
                            <Button Content="👁  Revelar esta imagen" Command="{Binding RevealCommand}"
                                    HorizontalAlignment="Center" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>

                    <Image Source="{Binding Image}" Stretch="Uniform" StretchDirection="DownOnly"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVis}}" />

                    <TextBlock Text="No se pudo decodificar como imagen; el archivo se conserva tal como llegó."
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding DecodeFailed, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </DockPanel>
        </DataTemplate>

        <!-- ══ Preview: PDF renderizado en memoria (sujeto a visibilidad) ══ -->
        <DataTemplate DataType="{x:Type pv:PdfPreviewViewModel}">
            <DockPanel Margin="8">
                <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
                        CornerRadius="4" Padding="10" Margin="0,8,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" Margin="12,0,0,0" />
                            <TextBlock Text="{Binding RenderStatusText}" Style="{StaticResource MonoText}"
                                       FontSize="11" Margin="12,0,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Text="{Binding Sha256, StringFormat=SHA-256: {0}}"
                                   Style="{StaticResource MonoText}" FontSize="11" Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid>
                    <!-- Placeholder de privacidad -->
                    <Border Background="{StaticResource PanelAltBrush}" CornerRadius="6"
                            Visibility="{Binding IsContentHidden, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="42" HorizontalAlignment="Center" />
                            <TextBlock Text="Documento oculto" Foreground="{StaticResource TextBrush}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,2" />
                            <TextBlock Text="El material sensible no se muestra hasta que lo decidas."
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12"
                                       HorizontalAlignment="Center" />
                            <Button Content="👁  Revelar este PDF" Command="{Binding RevealCommand}"
                                    HorizontalAlignment="Center" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Páginas renderizadas -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Pages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="{Binding PageNumber, StringFormat=página {0}}"
                                                   Style="{StaticResource MonoText}" FontSize="10"
                                                   HorizontalAlignment="Center" Margin="0,0,0,2" />
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <Image Source="{Binding Image}" Stretch="Uniform" StretchDirection="DownOnly"
                                                   RenderOptions.BitmapScalingMode="HighQuality" MaxWidth="900" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </DataTemplate>

        <!-- ══ Preview: texto extraído de un .docx ══ -->
        <DataTemplate DataType="{x:Type pv:DocxPreviewViewModel}">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" Margin="12,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding Sha256, StringFormat=SHA-256: {0}}"
                               Style="{StaticResource MonoText}" FontSize="11" Margin="0,2,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSha256, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="Texto extraído del documento (sin diseño); el archivo original está intacto."
                               Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorText}"
                           Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextBrush}"
                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </DockPanel>
        </DataTemplate>

        <!-- ══ Preview: reproductor de audio Opus (motor PR-Opus) ══ -->
        <DataTemplate DataType="{x:Type pv:AudioPreviewViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="6"
                    Padding="24" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="640">
                <StackPanel>
                    <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}"
                               FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center"
                               Margin="0,10,0,0" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Content="▶  Reproducir" Command="{Binding PlayCommand}" Margin="0,0,8,0" />
                        <Button Content="⏸  Pausa" Command="{Binding PauseCommand}" Margin="0,0,8,0" />
                        <Button Content="⏹  Detener" Command="{Binding StopCommand}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="🔉" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" Width="160"
                                VerticalAlignment="Center"
                                ToolTip="Volumen" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentGreenBrush}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ContentType}" Style="{StaticResource MonoText}" Foreground="{StaticResource TextBrush}" Margin="0,2" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tamaño" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource MonoText}" Foreground="{StaticResource TextBrush}" Margin="0,2" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA-256" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Sha256}" Style="{StaticResource MonoText}"
                                   Foreground="{StaticResource AccentGreenBrush}" TextWrapping="Wrap" Margin="0,2" />
                    </Grid>
                    <TextBlock Text="Reproducción desde memoria con el motor PR-Opus; el archivo original nunca se extrae ni se modifica."
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ══ Preview: ficha de metadatos (video, audio, documentos) ══ -->
        <DataTemplate DataType="{x:Type pv:FileInfoPreviewViewModel}">
            <Border Background="{StaticResource PanelBrush}" CornerRadius="6"
                    Padding="24" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="640">
                <StackPanel>
                    <TextBlock Text="{Binding Glyph}" FontSize="48" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EntryName}" Foreground="{StaticResource AccentCyanBrush}"
                               FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center"
                               Margin="0,10,0,0" TextWrapping="Wrap" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ContentType}" Style="{StaticResource MonoText}" Foreground="{StaticResource TextBrush}" Margin="0,2" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tamaño" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SizeText}" Style="{StaticResource MonoText}" Foreground="{StaticResource TextBrush}" Margin="0,2" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA-256" Foreground="{StaticResource TextDimBrush}" Margin="0,2,16,2" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Sha256Text}" Style="{StaticResource MonoText}"
                                   Foreground="{StaticResource AccentGreenBrush}" TextWrapping="Wrap" Margin="0,2" />
                    </Grid>
                    <TextBlock Text="Este tipo de contenido no se reproduce en el visor: se inspecciona por metadatos y hash."
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ══ Preview: adjunto ausente ══ -->
        <DataTemplate DataType="{x:Type pv:MissingAttachmentPreviewViewModel}">
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource MissingBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="24" Margin="24"
                    VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="640">
                <StackPanel>
                    <TextBlock Text="⚠" FontSize="42" Foreground="{StaticResource MissingBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="ADJUNTO AUSENTE" Foreground="{StaticResource MissingBrush}"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,4" />
                    <TextBlock Text="{Binding Name}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ContentType}" Style="{StaticResource MonoText}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,2,0,0" />
                    <TextBlock Text="El chat lo referencia pero no está en el paquete: señal de export incompleto."
                               Foreground="{StaticResource TextDimBrush}" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══ Encabezado ══ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="PR-VIEWER" Foreground="{StaticResource AccentCyanBrush}"
                               FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="3"
                            Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SOLO LECTURA" Foreground="{StaticResource AccentGreenBrush}"
                                   FontSize="10" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="El material inspeccionado nunca se modifica."
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton Style="{StaticResource MediaToggle}"
                                  IsChecked="{Binding MediaVisibility.ShowMedia}"
                                  Margin="0,0,8,0"
                                  ToolTip="El contenido visual arranca oculto para casos sensibles. Activalo cuando haga falta observar el material.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁" Margin="0,0,6,0" />
                            <TextBlock Text="Mostrar multimedia" />
                        </StackPanel>
                    </ToggleButton>
                    <Button Content="📦  Abrir paquete…" Command="{Binding OpenFileCommand}" Margin="0,0,8,0" />
                    <Button Content="📁  Abrir carpeta…" Command="{Binding OpenFolderCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Resumen de la conversación ══ -->
        <Border Grid.Row="1" Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,6"
                Visibility="{Binding HasConversation, Converter={StaticResource BoolToVis}}">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Plataforma: " Foreground="{StaticResource TextDimBrush}" />
                    <TextBlock Text="{Binding PlatformText}" Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Participantes: " Foreground="{StaticResource TextDimBrush}" />
                    <TextBlock Text="{Binding ParticipantsText}" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Período: " Foreground="{StaticResource TextDimBrush}" />
                    <TextBlock Text="{Binding DateRangeText}" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Mensajes: " Foreground="{StaticResource TextDimBrush}" />
                    <TextBlock Text="{Binding MessageCountText}" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Adjuntos: " Foreground="{StaticResource TextDimBrush}" />
                    <TextBlock Text="{Binding AttachmentSummaryText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMissingAttachments}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource MissingBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ══ Cuerpo: árbol/galería + preview ══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Margin="4">
                <TabItem Header="Entradas">
                    <TreeView ItemsSource="{Binding RootNodes}"
                              SelectedItemChanged="OnTreeSelectionChanged"
                              VirtualizingPanel.IsVirtualizing="True">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}"
                                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </TabItem>
                <TabItem Header="Multimedia">
                    <ListBox ItemsSource="{Binding Attachments}"
                             SelectedItem="{Binding SelectedAttachment}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="140" Margin="2" Padding="4" CornerRadius="4"
                                        Background="{StaticResource PanelAltBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource MissingBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Height="90">
                                            <!-- Miniatura revelada -->
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                                   Visibility="{Binding IsThumbnailVisible, Converter={StaticResource BoolToVis}}" />
                                            <!-- Miniatura oculta por privacidad -->
                                            <StackPanel VerticalAlignment="Center"
                                                        Visibility="{Binding IsThumbnailHidden, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="🔒" FontSize="22" HorizontalAlignment="Center" />
                                                <Button Content="revelar" Command="{Binding RevealCommand}"
                                                        FontSize="10" Padding="6,2" Margin="0,4,0,0"
                                                        HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <!-- Sin miniatura: glifo por tipo -->
                                            <StackPanel VerticalAlignment="Center"
                                                        Visibility="{Binding ShowGlyph, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Glyph}" FontSize="30" HorizontalAlignment="Center" />
                                                <TextBlock Text="AUSENTE" Foreground="{StaticResource MissingBrush}"
                                                           FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"
                                                           Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}" FontSize="10"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"
                                                   ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource MonoText}" FontSize="10" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

            <Border Grid.Column="2" Margin="4">
                <Grid>
                    <ContentControl Content="{Binding SelectedPreview}" />
                    <TextBlock Text="Seleccioná una entrada del árbol o un adjunto de la galería."
                               Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPreview}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ Barra de estado ══ -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Visibility="{Binding HasSource, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="SHA-256 del paquete: " Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                    <TextBlock Text="{Binding PackageSha256}" Style="{StaticResource MonoText}"
                               FontSize="11" Foreground="{StaticResource AccentGreenBrush}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDimBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
