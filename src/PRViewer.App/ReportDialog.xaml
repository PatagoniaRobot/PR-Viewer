<Window x:Class="PRViewer.App.ReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generar informe de inspección"
        Width="620" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <!-- Estilos de formulario locales (el tema no define TextBox/CheckBox). -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,4,16,4" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,10,2" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="El informe contiene exclusivamente metadatos, estadísticas y hashes del paquete — nunca el contenido de los mensajes. Los datos del caso son opcionales." />

        <!-- Caso judicial -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Caso judicial (opcional)" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition /><RowDefinition /><RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Nº de caso" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CaseNumberBox" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Nº actuación" Margin="12,2,10,2" />
                    <TextBox   Grid.Row="0" Grid.Column="3" x:Name="CaseFileNumberBox" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Carátula" />
                    <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="CaseNameBox" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Juzgado" />
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="CourtNameBox" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Fiscalía" Margin="12,2,10,2" />
                    <TextBox   Grid.Row="2" Grid.Column="3" x:Name="ProsecutorOfficeBox" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Perito -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Perito / examinador (opcional)" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition /><RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Nombre" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="ExaminerNameBox" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Legajo" Margin="12,2,10,2" />
                    <TextBox   Grid.Row="0" Grid.Column="3" x:Name="ExaminerBadgeBox" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="División" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ExaminerDivisionBox" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Cargo" Margin="12,2,10,2" />
                    <TextBox   Grid.Row="1" Grid.Column="3" x:Name="ExaminerRoleBox" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Recepción -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Recepción del material (opcional)" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition /><RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Recibido de" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="ReceivedFromBox" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Nº acta" Margin="12,2,10,2" />
                    <TextBox   Grid.Row="0" Grid.Column="3" x:Name="ReceivedActNumberBox" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Fecha (AAAA-MM-DD)" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ReceivedDateBox" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Salida -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Salida" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Carpeta destino" />
                    <TextBox   Grid.Column="1" x:Name="DestinationBox" />
                    <Button    Grid.Column="2" Content="Examinar…" Margin="8,2,0,2" Click="OnBrowseDestination" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="130,4,0,0">
                    <CheckBox x:Name="HtmlCheck" IsChecked="True" Content="HTML (imprimible a PDF desde el navegador)" />
                    <CheckBox x:Name="TxtCheck" IsChecked="True" Content="Texto plano" />
                </StackPanel>
                <TextBlock x:Name="ValidationText" Foreground="{StaticResource WarningBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="📄  Generar" Width="120" Click="OnAccept" />
        </StackPanel>
    </StackPanel>
</Window>
